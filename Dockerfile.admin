# Multi-stage Dockerfile for Admin (React + Vite + Refine)

# Stage 1: Base - Dependencies
FROM node:22-alpine AS base
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@10.12.4

# Copy package files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/admin/package.json ./apps/admin/
COPY infra/shared/package.json ./infra/shared/

# Install dependencies with pnpm cache mount
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

# Stage 2: Development
FROM base AS development
WORKDIR /app
COPY . .

# Install all dependencies with hoisting
RUN pnpm install --frozen-lockfile --shamefully-hoist

# Expose port
EXPOSE 5173

# Start development server
CMD ["pnpm", "dev:admin"]

# Stage 3: Build
FROM base AS builder
WORKDIR /app
COPY . .

# Accept build-time arguments for Vite environment variables
ARG VITE_API_URL=/trpc

# Build argument to environment variable for Vite
ENV VITE_API_URL=${VITE_API_URL}

# Build shared package first (admin depends on it)
RUN pnpm --filter @opencode/shared build

# Build admin
WORKDIR /app/apps/admin
RUN pnpm build

# Change back to root for next stage
WORKDIR /app

# Stage 4: Production (Nginx)
FROM nginx:alpine AS production

# ===== 时区配置（关键修复）=====
# 设置时区为北京时间（Asia/Shanghai）
# 确保 Admin 后台显示时间与数据库一致
ENV TZ=Asia/Shanghai
RUN apk add --no-cache tzdata && \
    ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apk del tzdata  # 删除包减小镜像体积（软链接已生效）

# Copy nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built files
COPY --from=builder /app/apps/admin/dist /usr/share/nginx/html

# Expose port
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
