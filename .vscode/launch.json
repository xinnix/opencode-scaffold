{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "NestJS: Attach",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "cwd": "${workspaceFolder}/apps/api",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/apps/api/dist/**/*.js"]
    },
    {
      "name": "Chrome: Admin",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/apps/admin/src"
    }
  ]
}
