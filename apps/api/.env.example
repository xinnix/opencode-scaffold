# API Server
# Port for the NestJS backend server
PORT=3000

# CORS
# CORS origin for frontend (comma-separated for multiple origins)
# Use "*" to allow all origins (development only)
CORS_ORIGIN="*"

# Node Environment
NODE_ENV=development

# JWT Configuration
# Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Access token expiration time (e.g., 15m, 1h, 1d)
JWT_EXPIRES_IN=1h
# Refresh token expiration time (e.g., 7d, 30d)
JWT_REFRESH_EXPIRES_IN=30d

# WeChat Mini Program Configuration
# 微信小程序 AppID
WX_APP_ID=
# 微信小程序 AppSecret (请勿泄露！)
WX_APP_SECRET=

# WeChat Pay Configuration
# 微信支付 AppID（通常与小程序 AppID 相同）
WX_PAY_APP_ID=
# 微信支付商户号
WX_PAY_MCH_ID=
# 微信支付 API v3 密钥（商户平台设置）
WX_PAY_API_KEY=
# 商户 API 证书序列号（商户平台 → API安全 → 证书）
WX_PAY_SERIAL_NO=
# 商户 API 私钥路径（从商户平台下载的 apiclient_key.pem）
WX_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem

# 微信支付公钥配置（2024年Q3新增，推荐使用）
# 微信支付公钥 ID（商户平台 → 账户中心 → API安全 → 微信支付公钥）
# 格式：PUB_KEY_ID_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
WX_PAY_PUBLIC_KEY_ID=
# 微信支付公钥路径（从商户平台下载的微信支付公钥文件）
WX_PAY_PUBLIC_KEY_PATH=./certs/wechatpay_public_key.pem

# 微信支付回调通知 URL（必须 HTTPS，指向你的服务器）
# 支付成功回调地址
WX_PAY_NOTIFY_URL=https://your-domain.com/api/payments/wechat/callback
# 退款结果回调地址（可选，默认使用支付回调地址）
WX_PAY_REFUND_NOTIFY_URL=https://your-domain.com/api/payments/wechat/refund-callback
# 支付环境: true=沙箱, false=正式(默认)
WX_PAY_SANDBOX=false

# File Storage Configuration
# File storage provider: local | aliyun-oss
FILE_STORAGE_PROVIDER=aliyun-oss

# Local Storage Configuration
# Path for local file uploads
UPLOAD_PATH=./uploads

# Aliyun OSS Configuration
# OSS endpoint (e.g., oss-cn-hangzhou.aliyuncs.com)
OSS_ENDPOINT=your-oss-endpoint
# OSS bucket name
OSS_BUCKET=your-bucket-name
# OSS access key ID
OSS_ACCESS_KEY_ID=your-access-key-id
# OSS access key secret
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS region
OSS_REGION=oss-cn-hangzhou

# Scheduler Configuration
# 定时任务开关（true=启用, false=禁用）
SCHEDULER_ENABLED=true
# 批处理大小（每次处理的订单数量）
SCHEDULER_BATCH_SIZE=100
# 订单超时时间（分钟）- 未支付订单自动取消
ORDER_TIMEOUT_MINUTES=15
# 自动退款开关（订单过期自动退款）
AUTO_REFUND_ENABLED=true
