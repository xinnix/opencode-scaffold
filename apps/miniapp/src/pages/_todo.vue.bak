<script setup lang="ts">
import { ref, onMounted, computed } from 'vue'
import { todoApi, type Todo } from '@/api/todo'

definePage({
  type: 'home',
})

// 状态
const todoList = ref<Todo[]>([])
const loading = ref(false)
const showAddModal = ref(false)
const editingTodo = ref<Todo | null>(null)

// 表单数据
const formData = ref({
  title: '',
  description: '',
  priority: 1,
})

// 弹窗标题
const modalTitle = computed(() => editingTodo.value ? '编辑 Todo' : '添加 Todo')

// 优先级文本
const priorityText: Record<number, string> = {
  1: '高',
  2: '中',
  3: '低',
}

// 优先级颜色
const priorityColor: Record<number, string> = {
  1: '#ff4d4f',
  2: '#faad14',
  3: '#52c41a',
}

// 加载 Todo 列表
const loadTodos = async () => {
  try {
    loading.value = true
    const res = await todoApi.getList()
    todoList.value = res.data.data || []
  } catch (error) {
    console.error('加载 Todo 列表失败:', error)
    uni.showToast({
      title: '加载失败',
      icon: 'none',
    })
  } finally {
    loading.value = false
  }
}

// 添加 Todo
const handleAdd = () => {
  editingTodo.value = null
  formData.value = {
    title: '',
    description: '',
    priority: 1,
  }
  showAddModal.value = true
}

// 编辑 Todo
const handleEdit = (todo: Todo) => {
  editingTodo.value = todo
  formData.value = {
    title: todo.title,
    description: todo.description || '',
    priority: todo.priority,
  }
  showAddModal.value = true
}

// 保存 Todo
const handleSave = async () => {
  if (!formData.value.title.trim()) {
    uni.showToast({
      title: '请输入标题',
      icon: 'none',
    })
    return
  }

  try {
    if (editingTodo.value) {
      // 更新
      await todoApi.update(editingTodo.value.id, formData.value)
      uni.showToast({
        title: '更新成功',
        icon: 'success',
      })
    } else {
      // 创建
      await todoApi.create(formData.value)
      uni.showToast({
        title: '创建成功',
        icon: 'success',
      })
    }
    showAddModal.value = false
    loadTodos()
  } catch (error) {
    console.error('保存失败:', error)
    uni.showToast({
      title: '保存失败',
      icon: 'none',
    })
  }
}

// 切换完成状态
const handleToggle = async (todo: Todo) => {
  try {
    await todoApi.toggleComplete(todo.id, !todo.isCompleted)
    uni.showToast({
      title: todo.isCompleted ? '已标记为未完成' : '已完成',
      icon: 'success',
    })
    loadTodos()
  } catch (error) {
    console.error('操作失败:', error)
    uni.showToast({
      title: '操作失败',
      icon: 'none',
    })
  }
}

// 删除 Todo
const handleDelete = (todo: Todo) => {
  uni.showModal({
    title: '确认删除',
    content: `确定要删除 "${todo.title}" 吗？`,
    success: async (res) => {
      if (res.confirm) {
        try {
          await todoApi.delete(todo.id)
          uni.showToast({
            title: '删除成功',
            icon: 'success',
          })
          loadTodos()
        } catch (error) {
          console.error('删除失败:', error)
          uni.showToast({
            title: '删除失败',
            icon: 'none',
          })
        }
      }
    },
  })
}

// 页面加载
onMounted(() => {
  loadTodos()
})
</script>

<template>
  <view class="todo-container">
    <!-- 头部 -->
    <view class="header">
      <text class="title">Todo List</text>
      <button class="add-btn" @click="handleAdd">
        <text>+ 添加</text>
      </button>
    </view>

    <!-- 列表 -->
    <view class="todo-list" v-if="!loading">
      <view
        v-for="todo in todoList"
        :key="todo.id"
        class="todo-item"
        :class="{ completed: todo.isCompleted }"
      >
        <view class="todo-content">
          <!-- 完成状态 -->
          <view class="checkbox" @click="handleToggle(todo)">
            <text v-if="todo.isCompleted" class="check-icon">✓</text>
          </view>

          <!-- 内容 -->
          <view class="todo-info">
            <view class="todo-header">
              <text class="todo-title">{{ todo.title }}</text>
              <view
                class="priority-tag"
                :style="{ backgroundColor: priorityColor[todo.priority] }"
              >
                {{ priorityText[todo.priority] }}
              </view>
            </view>
            <text v-if="todo.description" class="todo-desc">
              {{ todo.description }}
            </text>
          </view>
        </view>

        <!-- 操作按钮 -->
        <view class="todo-actions">
          <button class="action-btn edit" @click="handleEdit(todo)">编辑</button>
          <button class="action-btn delete" @click="handleDelete(todo)">删除</button>
        </view>
      </view>

      <!-- 空状态 -->
      <view v-if="todoList.length === 0" class="empty">
        <text class="empty-text">暂无 Todo，点击右上角添加</text>
      </view>
    </view>

    <!-- 加载中 -->
    <view v-else class="loading">
      <text>加载中...</text>
    </view>

    <!-- 添加/编辑弹窗 -->
    <view v-if="showAddModal" class="modal-mask" @click="showAddModal = false">
      <view class="modal" @click.stop="">
        <view class="modal-header">
          <text class="modal-title">{{ editingTodo ? '编辑 Todo' : '添加 Todo' }}</text>
        </view>

        <view class="modal-body">
          <view class="form-item">
            <text class="label">标题 *</text>
            <input
              v-model="formData.title"
              class="input"
              placeholder="请输入标题"
              maxlength="100"
            />
          </view>

          <view class="form-item">
            <text class="label">描述</text>
            <textarea
              v-model="formData.description"
              class="textarea"
              placeholder="请输入描述"
              maxlength="500"
            />
          </view>

          <view class="form-item">
            <text class="label">优先级</text>
            <view class="priority-options">
              <view
                v-for="(text, key) in priorityText"
                :key="key"
                class="priority-option"
                :class="{ active: formData.priority === Number(key) }"
                :style="{
                  borderColor: formData.priority === Number(key) ? priorityColor[Number(key)] : '#ddd'
                }"
                @click="formData.priority = Number(key)"
              >
                <text>{{ text }}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="modal-footer">
          <button class="btn cancel" @click="showAddModal = false">取消</button>
          <button class="btn confirm" @click="handleSave">保存</button>
        </view>
      </view>
    </view>
  </view>
</template>

<style lang="scss" scoped>
