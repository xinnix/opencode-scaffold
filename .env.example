# 开发环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ===========================
# 数据库配置（必需）
# ===========================
DATABASE_URL=postgresql://username:password@127.0.0.1/database_name

# ===========================
# 安全配置（必需）
# ===========================
# JWT 密钥（至少 32 个字符，生产环境务必更换）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===========================
# CORS 配置
# ===========================
CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# ===========================
# Rate Limiting
# ===========================
# 限流窗口（毫秒）
RATE_LIMIT_TTL_MS=60000
# 通用 API 限流（请求数/窗口）
RATE_LIMIT_GENERAL=100
# 认证端点限流（请求数/窗口）
RATE_LIMIT_AUTH=5

# ===========================
# 文件上传
# ===========================
# 最大文件大小（字节，默认 10MB）
MAX_FILE_SIZE=10485760

# ===========================
# 服务配置
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# 微信小程序（可选）
# ===========================
# WX_APP_ID=your-wechat-appid
# WX_APP_SECRET=your-wechat-appsecret

# ===========================
# 微信支付（可选）
# ===========================
# WX_PAY_MCH_ID=your-merchant-id
# WX_PAY_API_KEY_V3=your-api-v3-key
# WX_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
# WX_PAY_PUBLIC_KEY_PATH=./certs/wechatpay_public_key.pem
# WX_PAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify

# ===========================
# 对象存储 OSS（可选）
# ===========================
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET=your-bucket-name
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_PUBLIC_URL=https://your-cdn-domain.com
