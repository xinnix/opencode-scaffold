# ============================================
# OpenCode Scaffold 环境变量配置
# 复制为 .env 并填写实际值：cp .env.example .env
# ============================================

# ===========================
# 数据库（必需）
# ===========================
DATABASE_URL=postgresql://username:password@127.0.0.1/database_name

# ===========================
# 安全（必需）
# ===========================
# JWT 密钥 — 至少 32 字符，生产务必更换
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ===========================
# CORS
# ===========================
# 生产环境请替换为具体域名，禁止使用 *
CORS_ORIGIN="*"

# ===========================
# 限流
# ===========================
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5

# ===========================
# 服务
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# 微信小程序（可选）
# ===========================
# WX_APP_ID=your-wechat-appid
# WX_APP_SECRET=your-wechat-appsecret

# ===========================
# 微信支付（可选）
# ===========================
# WX_PAY_APP_ID=your-wechat-appid
# WX_PAY_MCH_ID=your-merchant-id
# WX_PAY_API_KEY=your-api-v3-key
# WX_PAY_SERIAL_NO=your-serial-no
# WX_PAY_PRIVATE_KEY_PATH=./certs/apiclient_key.pem
# WX_PAY_PUBLIC_KEY_ID=PUB_KEY_ID_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# WX_PAY_PUBLIC_KEY_PATH=./certs/wechatpay_public_key.pem
# WX_PAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify
# WX_PAY_REFUND_NOTIFY_URL=https://your-domain.com/api/payment/wechat/refund-notify
# WX_PAY_SANDBOX=false

# ===========================
# 企业微信 WeCom（可选）
# ===========================
# WX_WORK_CORP_ID=your-corp-id
# WX_WORK_SECRET=your-agent-secret
# WX_WORK_AGENT_ID=1000002
# WX_WORK_TOKEN=your-callback-token
# WX_WORK_ENCODING_AES_KEY=your-encoding-aes-key

# ===========================
# 文件上传
# ===========================
MAX_FILE_SIZE=10485760
# 存储策略：local | aliyun-oss
FILE_STORAGE_PROVIDER=local
UPLOAD_PATH=./uploads

# ===========================
# 阿里云 OSS（可选，FILE_STORAGE_PROVIDER=aliyun-oss 时必需）
# ===========================
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_BUCKET=your-bucket-name
# OSS_REGION=oss-cn-hangzhou
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ===========================
# Redis（可选）
# ===========================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ===========================
# 定时任务（可选）
# ===========================
# SCHEDULER_ENABLED=true
# SCHEDULER_BATCH_SIZE=100
# ORDER_TIMEOUT_MINUTES=15
# AUTO_REFUND_ENABLED=true
