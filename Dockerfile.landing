# Multi-stage Dockerfile for Landing (Next.js static export)

# Stage 1: Base - Dependencies
FROM node:22-alpine AS base
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@10.12.4

# Copy package files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/landing/package.json ./apps/landing/

# Install dependencies with pnpm cache mount
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

# Stage 2: Development
FROM base AS development
WORKDIR /app
COPY . .

# Install all dependencies with hoisting
RUN pnpm install --frozen-lockfile --shamefully-hoist

# Expose port
EXPOSE 3001

# Start development server
CMD ["pnpm", "dev:landing"]

# Stage 3: Build
FROM base AS builder
WORKDIR /app
COPY . .

# Build landing (static export to out/)
WORKDIR /app/apps/landing
RUN pnpm build

# Change back to root for next stage
WORKDIR /app

# Stage 4: Production (Nginx)
FROM nginx:alpine AS production

# 时区配置
ENV TZ=Asia/Shanghai
RUN apk add --no-cache tzdata && \
    ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apk del tzdata

# Copy nginx config
COPY nginx.landing.conf /etc/nginx/conf.d/default.conf

# Copy built files (Next.js static export outputs to out/)
COPY --from=builder /app/apps/landing/out /usr/share/nginx/html

# Expose port
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
