{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm -C :*)",
      "Bash(cd :*)",
      "Bash(npx prisma:*)",
      "Bash(npx prisma migrate dev:*)",
      "Bash(npx prisma generate:*)",
      "Bash(npx prisma studio:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log)",
      "Bash(git branch)",
      "Bash(git checkout)",
      "Bash(git ls-tree)",
      "Bash(chmod +x :*)",
      "Bash(mkdir -p :*)",
      "Bash(test -d :*)",
      "Bash(test -f :*)",
      "mcp__exa__get_code_context_exa",
      "mcp__exa__web_search_exa",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebSearch",
      "LSP"
    ],
    "deny": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh ./.claude/hooks/user-prompt-submit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "sh ./.claude/hooks/before-edit.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "sh ./.claude/hooks/after-edit.sh" }
        ]
      }
    ]
  }
}
