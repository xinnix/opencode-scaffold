# 生产环境配置（1panel 部署）
# 请根据实际情况修改以下配置

# ===== 数据库配置 =====
# PostgreSQL 连接地址（生产环境）
DATABASE_URL="postgresql://username:password@your-db-host:5432/couponHub"

# ===== JWT 配置 =====
JWT_SECRET="your-production-secret-key-min-32-characters-change-this"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# ===== CORS 配置 =====
# 允许的前端域名（多个用逗号分隔）
CORS_ORIGIN="https://your-admin-domain.com,https://your-miniapp-domain.com"

# ===== Rate Limiting =====
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5

# ===== 服务端口 =====
# API 服务内部端口（容器内）
PORT=3000
# Docker 端口映射（docker-compose.prod.yml 使用）
API_PORT=3001
ADMIN_PORT=8081

# ===== Node 环境 =====
NODE_ENV=production

# ===== 时区配置 =====
# 设置为北京时间，确保所有时间字段正确
TZ=Asia/Shanghai

# ===== 微信小程序配置 =====
# 微信小程序 AppID
WX_APP_ID=your_wechat_appid
# 微信小程序 AppSecret（请勿泄露！）
WX_APP_SECRET=your_wechat_appsecret

# ===== 微信支付配置 =====
# 微信支付 AppID（通常与小程序 AppID 相同）
WX_PAY_APP_ID=your_wechat_appid
# 微信支付商户号
WX_PAY_MCH_ID=your_mch_id
# 微信支付 API v3 密钥（商户平台设置）
WX_PAY_API_KEY=your_api_v3_key
# 商户 API 证书序列号（商户平台 → API安全 → 证书）
WX_PAY_SERIAL_NO=your_serial_no
# 微信支付私钥路径（容器内路径）
WX_PAY_PRIVATE_KEY_PATH=/app/certs/apiclient_key.pem
# 微信支付公钥 ID（2024年Q3新增，推荐）
WX_PAY_PUBLIC_KEY_ID=PUB_KEY_ID_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# 微信支付公钥路径（容器内路径）
WX_PAY_PUBLIC_KEY_PATH=/app/certs/wechatpay_public_key.pem
# 微信支付通知 URL（回调地址）
WX_PAY_NOTIFY_URL=https://your-api-domain.com/api/payments/wechat/callback
# 微信支付退款通知 URL
WX_PAY_REFUND_NOTIFY_URL=https://your-api-domain.com/api/payments/wechat/refund-callback
# 支付环境: true=沙箱, false=正式(默认)
WX_PAY_SANDBOX=false

# ===== 文件存储配置 =====
# 存储策略：local（本地）或 aliyun-oss（阿里云 OSS）
FILE_STORAGE_PROVIDER=local
# 上传文件路径（容器内）
UPLOAD_PATH=/app/uploads
# 最大文件大小（字节，默认 10MB）
MAX_FILE_SIZE=10485760

# ===== 阿里云 OSS 配置（可选）=====
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=

# ===== Redis 配置（可选）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== 定时任务配置（可选）=====
SCHEDULER_ENABLED=true
SCHEDULER_BATCH_SIZE=100
ORDER_TIMEOUT_MINUTES=15
AUTO_REFUND_ENABLED=true

# ===== 其他配置 =====
# 是否跳过数据库迁移（如果表已存在）
# SKIP_MIGRATION=true
