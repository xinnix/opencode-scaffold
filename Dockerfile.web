# Multi-stage Dockerfile for Web (Next.js SSR with standalone output)

# Stage 1: Base
FROM node:22-alpine AS base
RUN npm install -g pnpm@10.12.4
WORKDIR /app

# Stage 2: Dependencies
FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/
COPY infra/shared/package.json ./infra/shared/
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

# Stage 3: Build
FROM deps AS builder
WORKDIR /app
COPY . .
RUN pnpm --filter @opencode/shared build
RUN pnpm --filter @opencode/web build

# Stage 4: Production
FROM node:22-alpine AS runner
ENV TZ=Asia/Shanghai
RUN apk add --no-cache tzdata && \
    ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && \
    echo "Asia/Shanghai" > /etc/timezone && \
    apk del tzdata

WORKDIR /app
ENV NODE_ENV=production

# Copy standalone output
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public 2>/dev/null || true

EXPOSE 3002
ENV PORT=3002
CMD ["node", "apps/web/server.js"]
