# 生产环境变量配置模板
# 复制此文件为 .env.prod 并填写实际值

# ===========================
# 镜像配置
# ===========================
REGISTRY=ghcr.io
IMAGE_NAME=agenticrepo
TAG=v1-latest

# ===========================
# 端口配置
# ===========================
API_PORT=3000
ADMIN_PORT=80

# ===========================
# 数据库配置
# ===========================
# PostgreSQL 连接字符串（必需）
DATABASE_URL=postgresql://xinnix:x12345678@127.0.0.1/agenticrepo

# ===========================
# 安全配置
# ===========================
# JWT 密钥（必需，至少 32 个字符）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===========================
# CORS 配置
# ===========================
# 允许的前端域名，生产环境应该设置具体域名
CORS_ORIGIN=https://yourdomain.com

# ===========================
# 微信小程序配置
# ===========================
WX_APP_ID=your_wechat_app_id
WX_APP_SECRET=your_wechat_app_secret

# ===========================
# 微信支付配置（V3 API）
# ===========================
# 微信支付 AppID（通常与小程序 AppID 相同）
WX_PAY_APP_ID=your_wechat_pay_app_id
# 微信支付商户号
WX_PAY_MCH_ID=your_mch_id
# 微信支付 API v3 密钥（商户平台设置）
WX_PAY_API_KEY=your_api_v3_key
# 商户 API 证书序列号（商户平台 → API安全 → 证书）
WX_PAY_SERIAL_NO=your_serial_no
# 商户 API 私钥路径（容器内路径）
WX_PAY_PRIVATE_KEY_PATH=/app/certs/apiclient_key.pem
# 微信支付公钥 ID（商户平台 → 账户中心 → API安全 → 微信支付公钥）
# 格式：PUB_KEY_ID_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
WX_PAY_PUBLIC_KEY_ID=your_public_key_id
# 微信支付公钥路径（容器内路径）
WX_PAY_PUBLIC_KEY_PATH=/app/certs/wechatpay_public_key.pem
# 支付回调通知 URL（必须 HTTPS）
WX_PAY_NOTIFY_URL=https://your-domain.com/api/payments/wechat/callback
# 退款回调通知 URL（可选，默认使用支付回调地址）
WX_PAY_REFUND_NOTIFY_URL=https://your-domain.com/api/payments/wechat/refund-callback
# 支付环境: true=沙箱, false=正式(默认)
WX_PAY_SANDBOX=false

# ===========================
# 文件存储配置
# ===========================
# 存储提供商：local 或 aliyun-oss
FILE_STORAGE_PROVIDER=aliyun-oss
UPLOAD_PATH=./uploads

# ===========================
# 阿里云 OSS 配置（如果使用 OSS 存储）
# ===========================
OSS_ENDPOINT=oss-cn-zhangjiakou.aliyuncs.com
OSS_REGION=oss-cn-zhangjiakou
OSS_BUCKET=your-bucket-name
OSS_ACCESS_KEY_ID=your_access_key_id
OSS_ACCESS_KEY_SECRET=your_access_key_secret
OSS_USE_SIGNED_URL=false

# ===========================
# 前端配置
# ===========================
# 前端访问后端的 URL（必需）
VITE_API_URL=https://api.yourdomain.com/trpc
